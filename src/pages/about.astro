---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="Software engineer, Android developer, and technical writer." />
	</head>
	<body class="bg-gray-light dark:bg-gray-dark">
		<Header />
		<main class="max-w-4xl mx-auto px-4 py-12 animate-fade-in">
			<article class="glass p-8 md:p-12">
				<h1 class="text-4xl md:text-5xl mb-8">About Me</h1>

				<div class="prose prose-lg dark:prose-invert max-w-none leading-relaxed">
					<p>
						I'm Jephthah, a software engineer based in Nigeria. I've spent most of my career
						working across the stack — from Android mobile development to web applications — and
						I enjoy the challenge of building software that people actually want to use.
					</p>

					<p>
						Most recently, I worked as an Android Engineer at Carbon (One Finance and Investment),
						where I contributed to the Carbon mobile app. Before that, I've worked on various web
						and mobile projects that taught me the value of clean architecture, thoughtful testing,
						and shipping early.
					</p>

					<h2>What I Write About</h2>

					<p>
						This blog is where I share what I'm learning and thinking about in software engineering.
						Topics usually include web development, mobile engineering, developer tools, and the
						occasional post about career growth in tech.
					</p>

					<p>
						I write for two audiences: other developers who might find the content useful, and my
						future self who will inevitably forget how I solved that one obscure bug.
					</p>

					<h2>Get in Touch</h2>

					<p>
						You can find me on <a href="https://www.linkedin.com/in/afolayanseyi">LinkedIn</a>
						or <a href="https://github.com/Afolayan">GitHub</a>. I'm always open to connecting
						with other developers and discussing interesting projects.
					</p>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
